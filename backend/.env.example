# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# For LOCAL DEVELOPMENT (WAMP/XAMPP):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cadenza_music_db
# DB_SSL=false  (not needed for local WAMP)

# For RAILWAY PRODUCTION:
# These will be set via Railway Environment Variables dashboard.
# Railway automatically creates these env vars when you link a MySQL service.
# Important: DB_HOST can use either:
#   - Internal (faster, within Railway):  mysql.railway.internal
#   - Public (external access):            mysql-production-17a9.up.railway.app
#
# DB_HOST=mysql.railway.internal
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=<your_railway_mysql_password>
# DB_NAME=railway
# DB_SSL=true

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5000

# For LOCAL: Vite dev server
CORS_ORIGIN=http://localhost:5173

# For RAILWAY: Your Vercel frontend domain
# CORS_ORIGIN=https://my-cadenza.vercel.app